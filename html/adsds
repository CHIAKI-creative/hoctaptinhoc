<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="icon" type="image/x-icon" href="../assets/icon.ico">
        <title>HỌC TẬP TIN HỌC</title>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="../styles.css" rel="stylesheet">
        <link href="../codemirror-5.65.21/lib/codemirror.css" rel="stylesheet">
        <link href="../codemirror-5.65.21/theme/darcula.css" rel="stylesheet">
        <link href="../codemirror-5.65.21/theme/base16-light.css" rel="stylesheet">
        <script src="../codemirror-5.65.21/lib/codemirror.js"></script>
        <script src="../codemirror-5.65.21/mode/sql/sql.js"></script>
        <script src="../codemirror-5.65.21/addon/edit/closebrackets.js"></script>

        <!-- Thêm script này vào phần <head> hoặc trước khi đóng thẻ <body> -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/sql-wasm.js"></script>

    </head>
    <style>
        .table-wrapper {
            max-height: 400px;
            overflow: auto;
            margin-top: 10px;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            background: white;
        }
        .table { margin-bottom: 0; min-width: 100%; }
        .CodeMirror { font-size: 16px; border-radius: 8px; }
    </style>
    <body>
        <nav class="navbar navbar-dark bg-dark fixed-top" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="../index.html">
                    <img src="../assets/icon.png" alt="Logo" width="30" height="30" class="d-inline-block align-text-top">
                    <b>HỌC TẬP TIN HỌC</b>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasNavbar">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title">CƠ SỞ DỮ LIỆU</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
                    </div>
                    <div class="offcanvas-body text-dark">
                        <!-- Menu giữ nguyên như của bạn -->
                        <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Định nghĩa dữ liệu</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#">Tạo bảng (CREATE)</a></li>
                                    <li><a class="dropdown-item" href="#">Xóa bảng (DROP)</a></li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <div class="container-fluid" style="margin-top: 80px;">
            <div class="row g-4">
                <div class="col-12 col-md-6 border-end">
                    <div class="d-flex justify-content-between">
                        <div class="col-12 w-50">
                            <select id="setting-editor" class="form-select form-select-lg mb-3">
                                <option value="dark" selected>🌙 Dark</option>
                                <option value="light">☀️ Light</option>
                            </select>
                        </div>
                        <div>
                            <button id="button-copyCode" type="button" class="btn btn-lg btn-success"><i class="fas fa-copy"></i></button>
                            <button id="button-runCode" type="button" class="btn btn-lg btn-success"><i class="fas fa-play"></i></button>
                        </div>
                    </div>
                    <textarea id="editor">-- Nhập SQL tại đây
CREATE TABLE SINHVIEN (MaSV INT, HoTen TEXT, Diem FLOAT);
INSERT INTO SINHVIEN VALUES (1, 'Nguyen Van A', 8.5);
INSERT INTO SINHVIEN VALUES (2, 'Tran Thi B', 9.0);
SELECT * FROM SINHVIEN;</textarea>
                </div>
                <div class="col-12 col-md-6">
                    <div class="d-flex">
                        <div class="col-12 w-50">
                            <select class="form-select form-select-lg mb-3">
                                <option value="1" selected>Xem kết quả truy vấn</option>
                                <option value="2">Xem cấu trúc dữ liệu</option>
                            </select>
                        </div>
                    </div>
                    <div id="result-display"></div>
                </div>
            </div>
        </div>

        <script>
            // 1. Khởi tạo CodeMirror
            var editor = CodeMirror.fromTextArea(document.getElementById("editor"), {
                mode: "text/x-sql",
                theme: "darcula",
                lineNumbers: true,
                autoCloseBrackets: true
            });
            editor.setSize("100%", window.innerHeight - 150);

            // 2. KHỞI TẠO SQL.JS (Chỉ chạy 1 lần duy nhất khi load trang)
            let db;
            const config = {
                locateFile: filename => `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/${filename}`
            };

            initSqlJs(config).then(function(SQL) {
                db = new SQL.Database();
                console.log("SQL.js đã sẵn sàng!");
            }).catch(err => console.error("Lỗi khởi tạo SQL.js:", err));

            // 3. XỬ LÝ SỰ KIỆN RUN CODE
            var runBtn = document.getElementById("button-runCode");
            var resultDisplay = document.getElementById("result-display");

            runBtn.addEventListener("click", function() {
                if (!db) return; // Đợi DB khởi tạo xong
                
                resultDisplay.innerHTML = "";
                var fullCode = editor.getValue().trim();
                
                if (fullCode === "") {
                    resultDisplay.innerHTML = createAlert("danger", "LỖI: Vui lòng nhập đoạn lệnh SQL!");
                    return;
                }

                try {
                    // Chạy lệnh SQL (db.exec có thể chạy nhiều câu lệnh cách nhau bằng dấu ;)
                    let results = db.exec(fullCode);

                    if (results.length > 0) {
                        results.forEach(res => {
                            resultDisplay.insertAdjacentHTML('beforeend', createAlert("info", "TRUY VẤN THÀNH CÔNG"));
                            resultDisplay.insertAdjacentHTML('beforeend', createRealTable(res));
                        });
                    } else {
                        resultDisplay.insertAdjacentHTML('beforeend', createAlert("success", "THỰC THI HOÀN TẤT (Dữ liệu đã được cập nhật)"));
                    }
                } catch (err) {
                    resultDisplay.insertAdjacentHTML('beforeend', createAlert("danger", `LỖI SQL: ${err.message}`));
                }
            });

            // 4. HÀM TẠO BẢNG KẾT QUẢ
            function createRealTable(result) {
                let columns = result.columns;
                let values = result.values;

                let thead = `<tr>${columns.map(col => `<th>${col}</th>`).join('')}</tr>`;
                let tbody = values.map(row => {
                    return `<tr>${row.map(cell => `<td>${cell !== null ? cell : ''}</td>`).join('')}</tr>`;
                }).join('');

                return `
                    <div class="table-wrapper shadow-sm mb-4">
                        <table class="table table-bordered table-striped table-hover bg-white">
                            <thead class="table-dark">${thead}</thead>
                            <tbody>${tbody}</tbody>
                        </table>
                    </div>`;
            }

            // 5. HELPER FUNCTIONS
            function createAlert(type, message) {
                return `<div class="alert alert-${type} alert-dismissible fade show shadow-sm mb-2" role="alert">
                            <i class="fas ${getIcon(type)} me-2"></i> ${message}
                        </div>`;
            }

            function getIcon(type) {
                const icons = {
                    'success': 'fa-check-circle',
                    'danger': 'fa-database',
                    'info': 'fa-table',
                    'warning': 'fa-edit'
                };
                return icons[type] || 'fa-exclamation-triangle';
            }

            // 6. GIAO DIỆN KHÁC
            document.getElementById("setting-editor").addEventListener("change", function() {
                editor.setOption("theme", this.value === "dark" ? "darcula" : "base16-light");
            });

            document.getElementById("button-copyCode").addEventListener("click", function(){
                navigator.clipboard.writeText(editor.getValue());
                alert("Đã copy code!");
            });
        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>